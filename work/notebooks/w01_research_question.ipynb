      "source": [
        "import pandas as pd\n",
        "\n",
        "df = pd.read_csv(\"../../data/raw/content_refresh_anonymized.csv\")\n",
        "print(f\"rows: {len(df):,}   clients: {df.client_id.nunique()}\")\n",
        "\n",
        "# --- Number 1: do simple continuous signals move with performance at all? ---\n",
        "# avg_position == 0 means \"no data\" (per the data dictionary), not rank zero -> exclude those rows.\n",
        "has_position = df[df.avg_position > 0]\n",
        "candidate_signals = [\"avg_position\", \"ctr\", \"word_count\", \"content_age_days\",\n",
        "                      \"days_since_last_update\", \"engagement_rate\"]\n",
        "# trend_pct is the OUTCOME being explained here, never a feature -- see the label-trap gotcha.\n",
        "corrs = has_position[candidate_signals + [\"trend_pct\"]].corr()[\"trend_pct\"].drop(\"trend_pct\")\n",
        "print(\"\\nNumber 1 -- correlation of each candidate signal with movement (trend_pct):\")\n",
        "print(corrs.round(3).sort_values(key=abs, ascending=False))\n",
        "print(f\"strongest |r| among {len(candidate_signals)} candidate signals: {corrs.abs().max():.3f}\")\n",
        "\n",
        "# --- Number 2: but grouping by content_type tells a different story ---\n",
        "decline_by_type = df.groupby(\"content_type\")[\"trend_direction\"].apply(lambda s: (s == \"down\").mean()).sort_values(ascending=False)\n",
        "print(\"\\nNumber 2 -- share of pages tagged 'declining' (trend_direction == down), by content_type:\")\n",
        "print((decline_by_type * 100).round(1).astype(str) + \"%\")\n",
        "spread = decline_by_type.max() - decline_by_type.min()\n",
        "print(f\"spread between highest and lowest content_type: {spread*100:.1f} percentage points \"\n",
        "      f\"({decline_by_type.max()/decline_by_type.min():.1f}x)\")\n",
        "\n",
        "# --- Number 3: same \"flat overall, real once grouped\" pattern shows up for age_tier too ---\n",
        "decline_by_age = df.groupby(\"age_tier\")[\"trend_direction\"].apply(lambda s: (s == \"down\").mean()).sort_values(ascending=False)\n",
        "print(\"\\nNumber 3 -- share declining by age_tier:\")\n",
        "print((decline_by_age * 100).round(1).astype(str) + \"%\")\n"
      ]
    },
    {
